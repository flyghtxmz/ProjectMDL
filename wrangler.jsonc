{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "projectmdl",
  "main": "src/worker.js",
  "compatibility_date": "2026-03-17",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "MODAL_ROUTER_KV",
      "id": "c71c88aca2bb41bba9d26fe4518833a1"
    }
  ],
  "vars": {
    "DASHBOARD_TITLE": "ProjectMDL Router"
  }
}
